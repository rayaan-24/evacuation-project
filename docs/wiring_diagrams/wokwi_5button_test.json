    { "from": "esp32", "pin": "GND", "to": "btn_2", "pin": "3" },
    { "from": "esp32", "pin": "GND", "to": "btn_3", "pin": "3" },
    { "from": "esp32", "pin": "GND", "to": "btn_4", "pin": "3" },
    { "from": "esp32", "pin": "GPIO15", "to": "r_red", "pin": "1" },
    { "from": "r_red", "pin": "2", "to": "led_red", "pin": "A" },
    { "from": "led_red", "pin": "K", "to": "esp32", "pin": "GND1" },
    { "from": "esp32", "pin": "GPIO16", "to": "r_yellow", "pin": "1" },
    { "from": "r_yellow", "pin": "2", "to": "led_yellow", "pin": "A" },
    { "from": "led_yellow", "pin": "K", "to": "esp32", "pin": "GND1" },
    { "from": "esp32", "pin": "GPIO17", "to": "r_green", "pin": "1" },
    { "from": "r_green", "pin": "2", "to": "led_green", "pin": "A" },
    { "from": "led_green", "pin": "K", "to": "esp32", "pin": "GND1" }
  ]
