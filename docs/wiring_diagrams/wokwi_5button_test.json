{
  "version": 1,
  "author": "Smart Evacuation Project",
  "name": "ESP32 Emergency - 5 Button Test",
  "editor": "wokwi",
  "parts": [
    { "type": "board", "id": "esp32", "name": "ESP32 DevKit v1" },
    { "type": "part", "id": "btn_0", "name": "Button 0", "properties": { "pushButton": "true" } },
    { "type": "part", "id": "btn_1", "name": "Button 1", "properties": { "pushButton": "true" } },
    { "type": "part", "id": "btn_2", "name": "Button 2", "properties": { "pushButton": "true" } },
    { "type": "part", "id": "btn_3", "name": "Button 3", "properties": { "pushButton": "true" } },
    { "type": "part", "id": "btn_4", "name": "Button 4", "properties": { "pushButton": "true" } },
    { "type": "part", "id": "r_red", "name": "Resistor Red", "properties": { "resistance": "220" } },
    { "type": "part", "id": "r_yellow", "name": "Resistor Yellow", "properties": { "resistance": "220" } },
    { "type": "part", "id": "r_green", "name": "Resistor Green", "properties": { "resistance": "220" } },
    { "type": "part", "id": "led_red", "name": "LED Red", "properties": { "color": "red" } },
    { "type": "part", "id": "led_yellow", "name": "LED Yellow", "properties": { "color": "yellow" } },
    { "type": "part", "id": "led_green", "name": "LED Green", "properties": { "color": "green" } }
  ],
  "connections": [
    { "from": "btn_0", "pin": "1", "to": "esp32", "pin": "GPIO4" },
    { "from": "btn_1", "pin": "1", "to": "esp32", "pin": "GPIO4" },
    { "from": "btn_2", "pin": "1", "to": "esp32", "pin": "GPIO4" },
    { "from": "btn_3", "pin": "1", "to": "esp32", "pin": "GPIO4" },
    { "from": "btn_4", "pin": "1", "to": "esp32", "pin": "GPIO4" },
    { "from": "btn_0", "pin": "2", "to": "esp32", "pin": "GPIO9" },
    { "from": "btn_1", "pin": "2", "to": "esp32", "pin": "GPIO10" },
    { "from": "btn_2", "pin": "2", "to": "esp32", "pin": "GPIO11" },
    { "from": "btn_3", "pin": "2", "to": "esp32", "pin": "GPIO12" },
    { "from": "btn_4", "pin": "2", "to": "esp32", "pin": "GPIO13" },
